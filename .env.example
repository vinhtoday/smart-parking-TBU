# =============================================
# Smart Parking System - TBU
# Copy this file to .env and fill in your values
# =============================================

# --- DATABASE ---
DATABASE_URL=mysql://root:password@localhost:3306/parking_db

# --- NEXTAUTH (Authentication) ---
NEXTAUTH_SECRET=your-random-secret-string-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# --- WEBSOCKET (Socket.IO) ---
# Public URL cho Socket.IO client kết nối (trình duyệt)
# Default: http://localhost:3003
# Production: đổi thành ws://your-domain.com hoặc wss://your-domain.com
NEXT_PUBLIC_WS_URL=http://localhost:3003
WS_PORT=3003

# --- ARDUINO SERIAL BRIDGE ---
SERIAL_PORT=3004
ARDUINO_SERIAL_PORT=COM5
ARDUINO_BAUD_RATE=9600

# --- ARDUINO SECURITY ---
# Shared secret giữa Arduino Serial Bridge và Next.js API
# PHẢI đặt giá trị ngẫu nhiên mạnh cho production!
# Arduino gửi qua header: X-Arduino-Secret
# WebSocket bridge gửi qua: auth.secret
ARDUINO_API_SECRET=your-arduino-api-secret-change-this
ARDUINO_WS_SECRET=your-arduino-ws-secret-change-this
